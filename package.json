{
  "name": "idle-mmo-lite",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "api": "pnpm --filter @idle/api",
    "web": "pnpm --filter @idle/web",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "migration:run": "pnpm --filter @idle/api migration:run",
    "migration:revert": "pnpm --filter @idle/api migration:revert"
  }
}
